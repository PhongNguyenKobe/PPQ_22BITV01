# Backend Environment Variables
# Database Configuration
POSTGRES_USER=ppq_user
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=movie_db
POSTGRES_PORT=5432

# FastAPI Configuration
BACKEND_PORT=8000
DATABASE_URL=postgresql+asyncpg://ppq_user:change-me-in-production@localhost:5432/movie_db

# JWT Configuration
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production-12345
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# CORS Configuration
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000

# Application Settings
APP_NAME=PPQ API

# External APIs
TMDB_API_TOKEN=your-tmdb-api-key-here
