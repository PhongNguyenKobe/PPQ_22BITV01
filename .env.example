# .env.example - Copy this file to .env and update values
# This is the main environment file for docker-compose

# ============================================
# DATABASE CONFIGURATION
# ============================================
POSTGRES_USER=ppq_user
POSTGRES_PASSWORD=secure-password-change-this
POSTGRES_DB=movie_db
POSTGRES_PORT=5432

# ============================================
# BACKEND CONFIGURATION
# ============================================
BACKEND_PORT=8000
DATABASE_URL=postgresql+asyncpg://ppq_user:secure-password-change-this@db:5432/movie_db

JWT_SECRET_KEY=your-secret-jwt-key-minimum-32-characters-long-change-this
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000

APP_NAME=PPQ API - CineAI

# ============================================
# FRONTEND CONFIGURATION
# ============================================
FRONTEND_PORT=3000
NUXT_PUBLIC_API_BASE=http://localhost:8000/api/v1

# ============================================
# EXTERNAL SERVICES
# ============================================
TMDB_API_TOKEN=your-tmdb-api-key-from-tmdb-org

# Payment Gateway (Future)
# STRIPE_SECRET_KEY=
# VNPAY_MERCHANT_ID=
# MOMO_ACCESS_KEY=

# ============================================
# ENVIRONMENT
# ============================================
NODE_ENV=development
DEBUG=false
